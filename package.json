    "test:e2e": "playwright test --workers=1"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^20.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
